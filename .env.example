# このファイルをコピーして .env.local を作成し、実際の値を入力してください。
# cp .env.example .env.local
#
# 実際の値（キー・接続文字列など）は絶対にこのファイルやコミットに含めないこと。

# Supabaseプロジェクトの設定 > API から取得
# クライアント側でも使うため NEXT_PUBLIC_ プレフィックスが必要
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabaseプロジェクトの設定 > API から取得
# サーバー専用のシークレット。RLSを無視した管理者権限アクセスに使用（app/_lib/db/supabase-admin.ts）
# クライアントコンポーネントや NEXT_PUBLIC_ 系には絶対に含めないこと
SUPABASE_SERVICE_ROLE_KEY=

# PostgresへのDirect Connection文字列（app/_lib/db/postgres.tsのpg Poolで使用）
# Supabaseプロジェクトの設定 > Database > Connection string から取得
DATABASE_URL=

# 任意。本番の正規URLを固定したい場合のみ設定（app/_lib/url.ts）
# 未設定時はVercelが自動注入するVERCEL_URL、それも無ければlocalhost:3000にフォールバックする
SITE_URL=
